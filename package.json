{
  "name": "saint-joseph-catholic-church-site",
  "version": "2.4.0",
  "private": true,
  "scripts": {
    "build-analyze": "cross-env ANALYZE=true next build",
    "bulletins-ci": "ts-node --project ./tsconfig.scripts.json ./scripts/pdf-to-images.ts -ci",
    "bulletins": "ts-node --project ./tsconfig.scripts.json ./scripts/pdf-to-images.ts",
    "deploy": "npm run build",
    "dev": "cross-env NODE_ENV=development next dev",
    "build": "cross-env NODE_ENV=production next build",
    "lint": "cross-env NODE_ENV=development eslint . --cache --ext .ts",
    "netlify-noop": "node -e \"process.exit(0)\"",
    "local-cms": "npx @staticcms/proxy-server@^4",
    "redirects": "ts-node --project ./tsconfig.scripts.json ./scripts/generate-redirects.ts",
    "prettier": "prettier \"src/**/*.{js,jsx,ts,tsx}\" --write",
    "smoke:gate": "npm run type-check && npm run lint && npm run build && npm run smoke:test",
    "smoke:install": "playwright install",
    "smoke:serve": "npm run build && npm run smoke:serve:static",
    "smoke:serve:static": "node ./scripts/serve-export.mjs --root out --port 4173",
    "smoke:test": "playwright test",
    "smoke:test:update": "playwright test --update-snapshots",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --watch"
  },
  "dependencies": {
    "@dnd-kit/core": "6.1.0",
    "@dnd-kit/sortable": "8.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@ducanh2912/next-pwa": "10.2.9",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@ephox/katamari": "9.1.6",
    "@fortawesome/fontawesome-svg-core": "6.5.2",
    "@fortawesome/free-regular-svg-icons": "6.5.2",
    "@fortawesome/free-solid-svg-icons": "6.5.2",
    "@fortawesome/react-fontawesome": "0.2.0",
    "@fullcalendar/core": "6.1.11",
    "@fullcalendar/daygrid": "6.1.11",
    "@fullcalendar/google-calendar": "6.1.11",
    "@fullcalendar/list": "6.1.11",
    "@fullcalendar/react": "6.1.11",
    "@fullcalendar/timegrid": "6.1.11",
    "@mui/base": "^5.0.0-beta.70",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "@mui/system": "^5.18.0",
    "@mui/x-date-pickers": "7.2.0",
    "@staticcms/lite": "2.0.2",
    "@svgr/webpack": "8.1.0",
    "@tinymce/tinymce-react": "4.3.0",
    "date-fns": "3.6.0",
    "date-fns-tz": "3.1.3",
    "dompurify": "3.3.3",
    "fast-xml-parser": "4.3.6",
    "gray-matter": "4.0.3",
    "is-hotkey": "0.2.0",
    "js-yaml": "4.1.1",
    "lodash": "4.18.1",
    "next": "15.5.15",
    "normalize.css": "8.0.1",
    "pdf.js-extract": "0.2.1",
    "raw-loader": "4.0.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-number-format": "5.4.5",
    "react-rss": "2.0.1",
    "react-schemaorg": "2.0.0",
    "react-slideshow-image": "4.3.1",
    "react-window": "1.8.10",
    "schema-dts": "1.1.2",
    "tinymce": "6.7.3",
    "uuid": "13.0.0",
    "webp-converter": "2.3.3"
  },
  "devDependencies": {
    "@babel/core": "7.24.4",
    "@emotion/eslint-plugin": "11.11.0",
    "@next/eslint-plugin-next": "15.5.15",
    "@npmcli/git": "3.0.2",
    "@opentelemetry/api": "1.9.1",
    "@playwright/test": "1.58.2",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-window": "1.8.8",
    "@typescript-eslint/eslint-plugin": "7.7.0",
    "@typescript-eslint/parser": "7.7.0",
    "babel-eslint": "10.1.0",
    "canvas": "3.2.3",
    "cross-env": "10.1.0",
    "eslint": "8.53.0",
    "eslint-config-next": "15.5.15",
    "eslint-config-prettier": "9.1.0",
    "eslint-import-resolver-typescript": "3.5.2",
    "eslint-plugin-babel": "5.3.1",
    "eslint-plugin-import": "2.28.1",
    "eslint-plugin-unicorn": "52.0.0",
    "fs-extra": "11.3.4",
    "is-url": "1.2.4",
    "netlify-cli": "^24.9.0",
    "next-remove-imports": "1.0.13",
    "node-fetch": "3.3.2",
    "node-gyp": "12.2.0",
    "prettier": "3.8.1",
    "ts-node": "10.9.2",
    "typescript": "5.4.5",
    "webpack": "5.105.4",
    "yaml-loader": "0.9.0"
  },
  "prettier": {
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ],
    "trailingComma": "none",
    "singleQuote": true,
    "printWidth": 120
  }
}
