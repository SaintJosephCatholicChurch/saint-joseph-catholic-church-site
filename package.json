{
  "name": "saint-joseph-catholic-church-site",
  "version": "2.4.0",
  "private": true,
  "scripts": {
    "build-analyze": "cross-env ANALYZE=true next build --webpack",
    "bulletins-ci": "ts-node --project ./tsconfig.scripts.json ./scripts/pdf-to-images.ts -ci",
    "bulletins": "ts-node --project ./tsconfig.scripts.json ./scripts/pdf-to-images.ts",
    "deploy": "npm run build",
    "dev": "cross-env NODE_ENV=development next dev --webpack",
    "build": "cross-env NODE_ENV=production next build --webpack",
    "lint": "cross-env NODE_ENV=development eslint \"**/*.ts\" --cache",
    "netlify-noop": "node -e \"process.exit(0)\"",
    "redirects": "ts-node --project ./tsconfig.scripts.json ./scripts/generate-redirects.ts",
    "prettier": "prettier \"src/**/*.{js,jsx,ts,tsx}\" --write",
    "smoke:gate": "npm run type-check && npm run lint && npm run build && npm run smoke:test",
    "smoke:install": "playwright install",
    "smoke:serve": "npm run build && npm run smoke:serve:static",
    "smoke:serve:static": "node ./scripts/serve-export.mjs --root out --port 4173",
    "smoke:test": "playwright test",
    "smoke:test:update": "playwright test --update-snapshots",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --watch"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@ducanh2912/next-pwa": "10.2.9",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@ephox/katamari": "11.0.0",
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-regular-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@fortawesome/react-fontawesome": "3.3.1",
    "@fullcalendar/core": "6.1.20",
    "@fullcalendar/daygrid": "6.1.20",
    "@fullcalendar/google-calendar": "6.1.20",
    "@fullcalendar/list": "6.1.20",
    "@fullcalendar/react": "6.1.20",
    "@fullcalendar/timegrid": "6.1.20",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^7.3.10",
    "@mui/system": "^7.3.10",
    "@mui/x-date-pickers": "8.28.4",
    "@tinymce/tinymce-react": "6.3.0",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.1.3",
    "dompurify": "3.4.2",
    "fast-xml-parser": "5.7.3",
    "gray-matter": "4.0.3",
    "is-hotkey": "0.2.0",
    "js-yaml": "4.1.1",
    "lodash": "4.18.1",
    "next": "16.2.2",
    "normalize.css": "8.0.1",
    "pdf.js-extract": "1.0.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-number-format": "5.4.5",
    "react-rss": "2.0.1",
    "react-schemaorg": "2.0.1",
    "react-slideshow-image": "4.4.0",
    "react-window": "2.2.7",
    "schema-dts": "2.0.0",
    "tinymce": "8.5.0",
    "uuid": "13.0.2",
    "webp-converter": "2.3.3"
  },
  "devDependencies": {
    "@babel/core": "7.24.4",
    "@eslint/js": "9.39.1",
    "@next/eslint-plugin-next": "16.2.2",
    "@npmcli/git": "3.0.2",
    "@opentelemetry/api": "1.9.1",
    "@playwright/test": "1.58.2",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "canvas": "3.2.3",
    "cross-env": "10.1.0",
    "eslint": "9.39.3",
    "eslint-config-next": "16.2.2",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-unicorn": "52.0.0",
    "fs-extra": "11.3.4",
    "globals": "17.6.0",
    "is-url": "1.2.4",
    "netlify-cli": "^24.9.0",
    "node-fetch": "3.3.2",
    "node-gyp": "12.2.0",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "typescript": "5.4.5",
    "webpack": "5.106.2"
  },
  "prettier": {
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ],
    "trailingComma": "none",
    "singleQuote": true,
    "printWidth": 120
  }
}
